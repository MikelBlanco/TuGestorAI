db.url=jdbc:postgresql://localhost:5432/tugestorai
db.user=
db.password=

telegram.bot.token=
telegram.bot.username=

# URL pública del panel web (se muestra al autónomo cuando usa /panel)
panel.url=https://tudominio.com/panel

openai.api.key=

anthropic.api.key=

# Clave AES-256 para cifrar datos personales en BD.
# Genera una nueva con: openssl rand -base64 32
# En producción usa SIEMPRE la variable de entorno CRYPTO_SECRET_KEY
crypto.secret.key=

pdf.output.dir=/ruta/a/directorio/pdfs

# Email (Jakarta Mail / angus-mail)
# Variables de entorno equivalentes: EMAIL_SMTP_HOST, EMAIL_SMTP_PORT, etc.
email.smtp.host=
email.smtp.port=587
email.smtp.user=
email.smtp.password=
email.from=

# ─── Límites de protección de costes ─────────────────────────────────────────
# Variables de entorno equivalentes: LIMIT_AUDIO_MAX_DURATION, etc.

# Duración máxima de un audio aceptado (segundos). Defecto: 180 = 3 min
limit.audio.max.duration=180

# Tamaño máximo de un fichero de audio (bytes). Defecto: 1048576 = 1 MB
limit.audio.max.size=1048576

# Rate limit compartido (audio + texto) por usuario: máximo de peticiones en la última hora
limit.requests.per.hour=10

# Rate limit compartido (audio + texto) por usuario: máximo de peticiones en el último día
limit.requests.per.day=30

# Máximo de reintentos al llamar a Claude API si devuelve JSON inválido
limit.claude.max.retries=1

# Máximo de ediciones que el autónomo puede hacer sobre un borrador antes de confirmarlo
limit.edits.per.presupuesto=5

# Máximo de emails que un usuario puede recibir por día
limit.email.per.day=20

# Tope de coste diario global en euros. A €0,007 por audio y €0,001 por texto.
# Defecto: 3.00 € ≈ 428 audios de 1 min
limit.cost.daily.max=3.00

# Segundos tras los que se borran automáticamente los mensajes con documentos en Telegram.
# Defecto: 300 = 5 minutos
limit.telegram.doc.ttl=300

# ─── Notificaciones automáticas por email ────────────────────────────────────

# Recordatorio semanal: lista de presupuestos aceptados sin facturar.
# Solo se envía a autónomos que tengan pendientes. Si no hay, no se molesta.
# Días válidos: MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY
notificacion.recordatorio.enabled=true
notificacion.recordatorio.dia=MONDAY
notificacion.recordatorio.hora=09:00

# Resumen mensual: estadísticas del mes anterior.
# Se ejecuta diariamente a la hora indicada y solo envía el día configurado.
# dia: 1-28 (se evita 29-31 para compatibilidad con todos los meses)
notificacion.resumen.enabled=true
notificacion.resumen.dia=1
notificacion.resumen.hora=08:00
